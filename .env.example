# ══════════════════════════════════════════════════════════════════════════════
# Omniweb Agent Engine — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════

# ── Retell AI (voice + web calls) ─────────────────────────────────────────────
# Dashboard: https://dashboard.retellai.com — API key with webhook badge for signatures
RETELL_API_KEY=
# Retell agent ID for anonymous web sessions (marketing / demo)
RETELL_LANDING_AGENT_ID=
# Optional: Omniweb ``clients.id`` UUID for anonymous sessions: ``GET/POST /widget`` (no path UUID)
# and ``POST /api/deepgram/voice-agent/bootstrap`` with no body ``client_id``.
LANDING_PAGE_CLIENT_ID=
# If true, bootstrap requires client_id or LANDING_PAGE_CLIENT_ID (multi-tenant lockdown).
# Default false: omitting both uses the oldest AgentConfig row (demo / single-tenant).
WIDGET_REQUIRE_CLIENT_ID=false

# ── Tool webhooks (Retell custom tools → this API) ─────────────────────────────
TOOL_WEBHOOK_SECRET=change-me-use-a-strong-random-secret

# ── Twilio (Phone Numbers + SMS) ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+15551234567

# ── OpenAI (Post-call LLM Processing) ─────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Database ──────────────────────────────────────────────────────────────────
# Local development example only. In production, set this to your managed PostgreSQL URL.
DATABASE_URL=postgresql+asyncpg://omniweb:password@localhost:5432/omniweb_engine

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Stripe (Billing) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── App Security ──────────────────────────────────────────────────────────────
SECRET_KEY=change-me-use-a-strong-random-secret
INTERNAL_API_KEY=change-me-use-a-strong-random-secret

# ── App Settings ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
APP_BASE_URL=https://omniweb-engine-rs6fr.ondigitalocean.app
ENGINE_BASE_URL=https://omniweb-engine-rs6fr.ondigitalocean.app
# Dashboard + /landing + /widget: use the App Platform default URL (omniweb.ai is the public marketing site, not this app).
PLATFORM_URL=https://omniweb-engine-rs6fr.ondigitalocean.app
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Clerk (Dashboard Auth) ────────────────────────────────────────────────────
# Plaintext from https://dashboard.clerk.com → API Keys (not DO "EV[1:...]" encrypted values).
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_JWKS_URL=

# ── Shopify (Commerce Assistant App) ───────────────────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://omniweb-engine-rs6fr.ondigitalocean.app
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_API_VERSION=2026-07
SHOPIFY_SCOPES=read_products,read_discounts,write_discounts,read_orders,read_customers,read_themes,write_script_tags
