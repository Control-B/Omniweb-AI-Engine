# ══════════════════════════════════════════════════════════════════════════════
# Omniweb Agent Engine v2 — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════

# ── ElevenLabs (Voice + Text AI Engine) ───────────────────────────────────────
# Get your API key at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_DEFAULT_VOICE_ID=EXAVITQu4vr4xnSDxMaL   # Rachel / preferred female default voice for realtime TTS
# Webhook secret — set in ElevenLabs dashboard → Agent → Platform Settings
ELEVENLABS_WEBHOOK_SECRET=

# ── Twilio (Phone Numbers + SMS) ──────────────────────────────────────────────
# Buy numbers from Twilio, import into ElevenLabs for voice.
# Twilio also handles all SMS sending.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+15551234567

# ── OpenAI (Post-call LLM Processing) ────────────────────────────────────────
# Used for lead extraction from transcripts (NOT for the voice agent itself)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://omniweb:password@localhost:5432/omniweb_engine

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Stripe (Billing) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── App Security ──────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-use-a-strong-random-secret
INTERNAL_API_KEY=change-me-use-a-strong-random-secret

# ── App Settings ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
APP_BASE_URL=https://api.omniweb.ai
ENGINE_BASE_URL=https://api.omniweb.ai
PLATFORM_URL=https://omniweb.ai
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
