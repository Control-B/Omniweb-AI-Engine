# Omniweb Agent Engine (FastAPI) — required for admin API + widget in production builds.
# NEXT_PUBLIC_API_URL overrides this for API-only if you ever split hosts.
NEXT_PUBLIC_ENGINE_URL=http://localhost:8000
# Same as API ``LANDING_PAGE_CLIENT_ID`` — anonymous ``/widget`` sends this in bootstrap body.
NEXT_PUBLIC_LANDING_PAGE_CLIENT_ID=
# This Next.js app (widget at /widget/{client_id}). Not the marketing site (omniweb.ai).
NEXT_PUBLIC_PLATFORM_URL=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:8000
# Clerk (same pk as FastAPI `CLERK_PUBLISHABLE_KEY` in repo root `.env`).
# Either name works; if you only set `CLERK_PUBLISHABLE_KEY` in `../.env`, next.config maps it.
CLERK_PUBLISHABLE_KEY=
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
